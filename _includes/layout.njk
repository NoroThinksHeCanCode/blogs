<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title or "My Blog" }}</title>
  <style>
    body { 
      background-color: #121212 !important; 
      color: #f0f0f0 !important;           
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; 
      max-width: 800px; 
      margin: 40px auto; 
      padding: 0 20px; 
      line-height: 1.6; 
    }
    h1, h2, h3, h4, h5, h6 { color: #ffffff !important; }
    nav { margin-bottom: 20px; padding-bottom: 10px; border-bottom: 1px solid #333; }
    nav a, a { text-decoration: none; color: #4db8ff !important; font-weight: bold; }
    a:hover { text-decoration: underline; }
    pre, code { background-color: #2d2d2d; color: #f8f8f2; padding: 3px 6px; border-radius: 4px; font-family: monospace; }
  </style>
</head>
<body>
  <nav>
    <a href="{{ '/' | url }}">← Home</a>
  </nav>

  {{ content | safe }}

</body>
</html>

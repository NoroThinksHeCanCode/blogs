<style>
  /* Fixed Dark Theme Variables */
  :root {
    --bg-color: #1a1a1a;        /* Sleek Charcoal */
    --text-color: #e0e0e0;      /* Soft White */
    --link-color: #4db8ff;      /* Electric Blue */
    --nav-border: #333333;      /* Subtle Divider */
    --code-bg: #2d2d2d;         /* Darker Gray for Python snippets */
  }

  body { 
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; 
    max-width: 800px; 
    margin: 40px auto; 
    padding: 0 20px; 
    line-height: 1.6; 
    background-color: var(--bg-color);
    color: var(--text-color);
  }

  nav { 
    margin-bottom: 20px; 
    padding-bottom: 10px; 
    border-bottom: 1px solid var(--nav-border); 
  }

  nav a, a { 
    text-decoration: none; 
    color: var(--link-color); 
    font-weight: bold; 
  }

  a:hover { 
    text-decoration: underline; 
    opacity: 0.8;
  }

  /* Style for your code blocks */
  pre, code {
    background-color: var(--code-bg);
    padding: 3px 6px;
    border-radius: 4px;
    font-family: 'Courier New', Courier, monospace;
    font-size: 0.9em;
  }
</style>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title or "My Blog" }}</title>
  <style>
  /* Base Styles */
  body { 
    background-color: #121212 !important; 
    color: #f0f0f0 !important;           
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; 
    line-height: 1.6; 
    
    /* MOBILE FIX: Use max-width but remove the huge 40px auto margin on small screens */
    max-width: 800px; 
    margin: 20px auto; /* Reduced from 40px */
    padding: 0 20px; 
  }

  /* IMPROVED HEADINGS for Mobile */
  h1 { font-size: 1.8rem; margin-top: 1.5rem; }
  h2 { font-size: 1.5rem; }
  h1, h2, h3, h4, h5, h6 { color: #ffffff !important; }

  /* NAVIGATION */
  nav { 
    margin-bottom: 2rem; 
    padding-bottom: 1rem; 
    border-bottom: 1px solid #333; 
  }
  nav a, a { 
    text-decoration: none; 
    color: #4db8ff !important; 
    font-weight: bold; 
    word-wrap: break-word; /* Prevents long URLs from breaking layout */
  }

  /* MOBILE-FRIENDLY CODE BLOCKS */
  pre, code { 
    background-color: #2d2d2d; 
    color: #f8f8f2; 
    padding: 3px 6px; 
    border-radius: 4px; 
    font-family: monospace; 
    font-size: 0.9em;
    /* ALLOW HORIZONTAL SCROLLING FOR CODE */
    overflow-x: auto;
    display: block; 
    white-space: pre-wrap; 
  }

  /* MEDIA QUERY: Adjustments for very small screens */
  @media (max-width: 600px) {
    body {
      margin: 10px auto;
      padding: 0 15px;
      font-size: 17px; /* Slightly larger text for easier reading on phones */
    }
  }
  </style>
</head>
<body>
  <nav>
    <a href="{{ '/' | url }}">← Home</a>
  </nav>

  {{ content | safe }}

</body>
</html>
